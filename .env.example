# ─────────────────────────────────────────────
# YouTube Downloader — 環境變數配置範本
# 複製此檔案為 .env 並填入你的設定
# ─────────────────────────────────────────────

# ── 登入認證 (必填) ────────────────────────────
YT_AUTH_USER=your@email.com
YT_AUTH_PASS=your_password_here

# ── 工具路徑 (選填，留空則自動偵測) ───────────────
# Linux / macOS (Homebrew) 通常無需設定，自動偵測
# Windows 原生環境建議明確指定：

# yt-dlp 路徑
# Windows (winget):  YT_DLP_PATH=C:\Users\USERNAME\AppData\Local\Microsoft\WinGet\Links\yt-dlp.exe
# macOS (brew):      YT_DLP_PATH=/opt/homebrew/bin/yt-dlp
# YT_DLP_PATH=

# ffmpeg 路徑
# Windows (winget):  FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# macOS (brew):      FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# FFMPEG_PATH=

# ── Google Drive (macOS / Linux / WSL2 only) ───
# Windows 原生環境不支援 Google Drive 自動上傳
# gog CLI 安裝後自動偵測，通常無需設定

# ── Telegram 通知 (選填，需要 OpenClaw) ──────────
# TG_GROUP=-1001234567890
# TG_TOPIC=1
